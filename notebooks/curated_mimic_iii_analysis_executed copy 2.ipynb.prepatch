      "metadata": {
        "execution": {
          "iopub.execute_input": "2026-04-01T20:58:43.151834Z",
          "iopub.status.busy": "2026-04-01T20:58:43.151680Z",
          "iopub.status.idle": "2026-04-01T20:58:54.698502Z",
